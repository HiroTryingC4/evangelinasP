# ─────────────────────────────────────────────────────────
#  Unit Booking System — Environment Variables
# ─────────────────────────────────────────────────────────
#
#  HOW TO USE:
#  1. Copy this file:  cp .env.example .env.local
#  2. Replace the placeholder below with your real Neon URL
#  3. Never commit .env.local to GitHub (it's in .gitignore)
#
# ─────────────────────────────────────────────────────────

# Get this from: Neon dashboard → your project → Connection Details
# Or from: Vercel dashboard → Storage → your DB → .env.local tab
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
